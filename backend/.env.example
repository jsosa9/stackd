# Environment (set to "production" on Railway)
ENV=development

# Supabase (get from Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sent.dm (get from https://app.sent.dm → Settings → API Keys)
SENT_API_KEY=your-sentdm-api-key
# Your provisioned Sent.dm phone number in E.164 format
SENT_PHONE_NUMBER=+1XXXXXXXXXX
# UUID of the SMS template created in the Sent.dm dashboard (used for all outbound SMS)
SENT_SMS_TEMPLATE_ID=your-template-uuid
# Webhook secret from the Sent.dm dashboard → Webhooks (format: whsec_xxxx)
SENT_WEBHOOK_SECRET=whsec_your-webhook-secret

# AI APIs
GEMINI_API_KEY=your-gemini-key
PERPLEXITY_API_KEY=your-perplexity-key

# Frontend URL (Vercel URL in production, localhost in dev)
FRONTEND_URL=https://your-app.vercel.app
