# Environment (set to "production" on Railway)
ENV=development

# Supabase (get from Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sendblue (get from dashboard.sendblue.co → API Keys)
SENDBLUE_API_KEY=your-sendblue-api-key-id
SENDBLUE_API_SECRET=your-sendblue-api-secret-key
# Your Sendblue number in E.164 format — found in dashboard → Numbers
SENDBLUE_PHONE_NUMBER=+1XXXXXXXXXX
# Webhook signing secret — optional, set if Sendblue provides one
SENDBLUE_WEBHOOK_SECRET=your-sendblue-webhook-secret

# AI APIs
GEMINI_API_KEY=your-gemini-key
PERPLEXITY_API_KEY=your-perplexity-key

# Frontend URL (Vercel URL in production, localhost in dev)
FRONTEND_URL=https://your-app.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
