# Environment (set to "production" on Railway)
ENV=development

# Supabase (get from Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Blooio (get from app.blooio.com dashboard → API Keys)
BLOOIO_API_KEY=your-blooio-api-key
# Your Blooio number in E.164 format — found in dashboard → Numbers
BLOOIO_PHONE_NUMBER=+1XXXXXXXXXX
# Webhook signing secret — shown once when you create the webhook in Blooio dashboard
BLOOIO_WEBHOOK_SECRET=your-blooio-webhook-secret

# AI APIs
GEMINI_API_KEY=your-gemini-key
PERPLEXITY_API_KEY=your-perplexity-key

# Frontend URL (Vercel URL in production, localhost in dev)
FRONTEND_URL=https://your-app.vercel.app
